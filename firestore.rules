rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access for fence status and sensor data
    match /fence_status/{statusId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sensor_data/{sensorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}